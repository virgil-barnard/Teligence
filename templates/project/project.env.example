# Required for compose interpolation
PROJ=myproj

# Image build base
BASE_IMAGE=ubuntu:24.04

# Tool versions (optional)
GH_VERSION=2.57.0
GLAB_VERSION=1.46.0
# OPENCODE_VERSION=0.15.16

# Image tag (optional)
IMAGE_TAG=agent-myproj:latest

# Repo bootstrap (optional)
REPO_URL=
REPO_DIR=/workspace/repo
REPO_BRANCH=

# Extra docker-compose settings (optional)
# Put mounts/ports/devices in projects/<proj>/compose.yaml instead of here.
